# Copy to .env and fill for Docker Compose
# JWT (must match across backend and admin; use a long random string in production)
JWT_SECRET=change-me-in-production

# Google Sign-In: client ID(s). For Android app login use your Android OAuth 2.0 client ID.
# Multiple IDs (Android + Web) comma-separated: GOOGLE_CLIENT_ID=AndroidId,WebClientId
GOOGLE_CLIENT_ID=

# PostgreSQL (Nest backend)
PG_USER=heyypal
PG_PASSWORD=heyypal
PG_DATABASE=heyypal

# Optional: Nest backend (Redis/RabbitMQ use defaults if unset)
# RABBITMQ_USER=guest
# RABBITMQ_PASS=guest
# PII_ENCRYPTION_KEY=your-32-byte-secret-key-here!!

# Admin panel: public API base URL (baked in at build time; must be reachable from the user's browser)
# Local (nginx on 8080): http://localhost:8080
# VPS / production: use your server IP or domain and the port where nginx is exposed, e.g.:
NEXT_PUBLIC_API_URL=http://187.77.191.120:8080
