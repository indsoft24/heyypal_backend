# Copy to .env and fill for Docker Compose
# JWT (must match across backend and admin; use a long random string in production)
JWT_SECRET=change-me-in-production

# Google Sign-In client ID (Android OAuth 2.0 client)
GOOGLE_CLIENT_ID=

# MySQL (used by backend and init)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=heyypal
MYSQL_USER=heyypal
MYSQL_PASSWORD=heyypal

# Admin panel: public URL where browser reaches the app (for API calls)
# With nginx on port 80: http://localhost
NEXT_PUBLIC_API_URL=http://localhost
