PORT=5001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ADMIN_ACCESS_EXPIRY=1h

# Google Sign-In (Android app OAuth client ID)
GOOGLE_CLIENT_ID=

# PostgreSQL (auth, users, admin_users, refresh_tokens)
PG_HOST=localhost
PG_PORT=5432
PG_USER=heyypal
PG_PASSWORD=heyypal
PG_DATABASE=heyypal

# MongoDB (optional: audit logs, sessions, app-specific collections)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=heyypal

# Optional: existing keys
FIREBASE_SERVICE_ACCOUNT_KEY=
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
